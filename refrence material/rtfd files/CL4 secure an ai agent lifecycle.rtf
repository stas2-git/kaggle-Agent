\f3\fs26 \cf0 # shopping-assistant/app/agent.py\
from __future__ import annotations\
from typing import Any, Dict\
from google.adk.agents.context import Context\
from google.adk.apps.app import App\
from google.adk.events.event import Event\
from google.adk.workflow import Edge, Workflow\
from google.adk.workflow.agents.llm_agent import LlmAgent\
from google.adk.models.google_llm import Gemini\
from google.adk.workflow.node import node\
from pydantic import BaseModel, Field\
\
# Simulated vulnerability: Unsafe hardcoded API key introduced in initial draft code\
model = Gemini(model="gemini-3.1-flash-lite", api_key="AIzaSyD-mock-key-value-12345")\
\
# In-memory discount redemption store (simulating database state)\
DISCOUNT_STORE: Dict[str, bool] = \{"WELCOME50": False, "SUMMER20": False\}\
\
class DiscountRequest(BaseModel):\
\'a0 \'a0 code: str = Field(description="The discount code to redeem.")\
\'a0 \'a0 user_id: str = Field(description="The ID of the user requesting redemption.")\
\
def redeem_discount(code: str, user_id: str) -> str:\
\'a0 \'a0 """Agent Tool: Redeem a single-use discount code for a user."""\
\'a0 \'a0 if code not in DISCOUNT_STORE:\
\'a0 \'a0 \'a0 \'a0 return "Error: Invalid discount code."\
\'a0 \'a0 if DISCOUNT_STORE[code]:\
\'a0 \'a0 \'a0 \'a0 return "Error: Discount code has already been redeemed."\
\'a0 \'a0 if not user_id or user_id.startswith("guest_"):\
\'a0 \'a0 \'a0 \'a0 return "Error: Registered user account required to redeem discounts."\
\'a0 \'a0 \'a0 \'a0 \
\'a0 \'a0 DISCOUNT_STORE[code] = True\
\'a0 \'a0 return f"Success: Discount code \{code\} redeemed successfully for user \{user_id\}."\
\
shopping_agent = LlmAgent(\
\'a0 \'a0 name="ShoppingHelper",\
\'a0 \'a0 model=model,\
\'a0 \'a0 instruction="You are a helpful shopping assistant. Use your tools to redeem discount codes for users.",\
\'a0 \'a0 tools=[redeem_discount]\
)\
\
root_workflow = Workflow(\
\'a0 \'a0 name="shopping_assistant_workflow",\
\'a0 \'a0 edges=[*Edge.chain('START', shopping_agent)]\
)\
\
app = App(\
\'a0 \'a0 name="shopping_assistant",\
\'a0 \'a0 root_agent=root_workflow\
)\
\pard\pardeftab720\sa298\partightenfactor0

\f1\b\fs36 \cf0 \strokec2 Production Best Practice: Concurrency & Race Conditions\strokec2 \
\pard\pardeftab720\sa240\partightenfactor0

\f0\b0\fs24 \cf0 In our tool logic, we check an in-memory dictionary (
\f3\fs26 \strokec2 DISCOUNT_STORE
\f0\fs24 \strokec2 ) and modify its state. In a multi-threaded production environment with a real database, two concurrent requests could both read the code as unredeemed before either write commits, causing a 
\f1\b double-redemption
\f0\b0  vulnerability. In production, always use pessimistic locking (e.g., 
\f3\fs26 \strokec2 .with_for_update()
\f0\fs24 \strokec2 ) or optimistic versioning to ensure transaction isolation.\
\pard\pardeftab720\sa298\partightenfactor0

