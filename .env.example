# Copy this file to `.env` or export the variables you need.
# Defaults favor reproducible local judging without live model credentials.

# Optional. Required only for live Gemini API calls.
# Leave empty for offline runs. Online mode without this key falls back to
# Application Default Credentials / Vertex AI if configured locally.
GEMINI_API_KEY=

# Runtime config.
PORTFOLIO_AGENT_EXECUTION_MODE=offline
PORTFOLIO_AGENT_MODEL=gemini-2.5-flash
PORTFOLIO_AGENT_THRESHOLD_PROFILE=default_actuarial_config
PORTFOLIO_AGENT_REPORTS_DIR=outputs/reports
PORTFOLIO_AGENT_TRACES_DIR=outputs/traces

# Optional. Set only if running commands from outside `project_build/`.
# PORTFOLIO_AGENT_PROJECT_ROOT=/absolute/path/to/project_build

# Optional FastAPI port.
# PORT=8080

# Optional metadata-only GenAI telemetry upload to GCS.
# LOGS_BUCKET_NAME=your-gcs-bucket-name
# GENAI_TELEMETRY_PATH=completions
# OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=NO_CONTENT
