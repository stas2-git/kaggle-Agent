{
  "actions": [
    {
      "action": "create-sheet",
      "sheet": "Summary",
      "if_exists": "reuse"
    },
    {
      "action": "write-cells",
      "sheet": "Summary",
      "cells": {
        "A1": "Summary",
        "A3": "Metric",
        "B3": "Value"
      }
    },
    {
      "action": "set-style",
      "sheet": "Summary",
      "ranges": ["A1:B1"],
      "preset": "section_header"
    },
    {
      "action": "set-column-widths",
      "sheet": "Summary",
      "widths": {
        "A": 24,
        "B": 14
      }
    }
  ]
}
